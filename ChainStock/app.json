{
  "expo": {
    "name": "ChainStock",
    "slug": "chainstock",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#4F46E5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.chainstock"
    },
    "android": {
      "package": "com.yourcompany.chainstock",
      "adaptiveIcon": {
        "backgroundColor": "#4F46E5"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1186a82a-b4f0-48ad-88a8-6c155bf5a30b"
      }
    }
  }
}
